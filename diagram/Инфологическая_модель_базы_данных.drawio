<mxfile host="Electron">
  <diagram name="Инфологическая модель БД" id="hostilioInfo01">
    <mxGraphModel dx="1815" dy="1375" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

